---
---

<div class="support-chat-root" data-support-panel>
    <div class="support-chat-guest" data-support-guest hidden>
        <p class="support-chat-guest-title">Support-Chat</p>
        <p class="support-chat-guest-text">
            Für den Live-Chat mit unserem Team bitte anmelden.
        </p>
        <a class="support-chat-login-btn" data-support-login href="/login?redirect=%2Fkontakt%3Fmode%3Dchat">
            Jetzt anmelden
        </a>
    </div>

    <div class="support-chat-card" data-support-card hidden>
        <header class="support-chat-header">
            <div class="support-chat-header-text">
                <h3 class="support-chat-title">Support-Chat</h3>
                <p class="support-chat-sub">Wir antworten dir hier im Chat</p>
                <p class="support-chat-matrix-hint" data-support-matrix-hint hidden></p>
            </div>
            <div class="support-chat-header-actions">
                <span class="support-chat-live">
                    <span class="support-chat-live-dot" aria-hidden="true"></span>
                    Live
                </span>
                <button
                    type="button"
                    class="support-chat-back"
                    data-support-back
                    aria-label="Zum Kontaktformular"
                    title="Zum Formular"
                >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>
        </header>

        <div class="support-chat-body">
            <div class="support-chat-loading" data-support-loading hidden>
                <span class="support-chat-spinner" aria-hidden="true"></span>
            </div>
            <div class="support-chat-messages" data-support-messages role="log" aria-live="polite"></div>
        </div>

        <div class="support-chat-input-row">
            <textarea
                data-support-input
                class="support-chat-input"
                rows="1"
                maxlength="2000"
                placeholder="Nachricht an den Support…"
                aria-label="Nachricht an den Support"
            ></textarea>
            <button type="button" class="support-chat-send" data-support-send aria-label="Senden" disabled>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                </svg>
            </button>
        </div>
    </div>
</div>

<style>
    .support-chat-root {
        width: 100%;
    }

    .support-chat-guest,
    .support-chat-start {
        text-align: center;
        padding: 28px 16px;
    }

    .support-chat-guest-title {
        color: white;
        font-size: 1.05rem;
        font-weight: 900;
        margin: 0 0 8px;
    }

    .support-chat-guest-text,
    .support-chat-start-text {
        color: var(--text-muted);
        font-size: 0.88rem;
        line-height: 1.5;
        margin: 0 0 18px;
    }

    .support-chat-login-btn,
    .support-chat-start-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 12px;
        padding: 12px 22px;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
        background: var(--cyan);
        color: #000;
        transition: filter 0.2s ease;
    }

    .support-chat-login-btn:hover,
    .support-chat-start-btn:hover {
        filter: brightness(1.08);
    }

    .support-chat-card {
        display: flex;
        flex-direction: column;
        height: min(480px, 62vh);
        min-height: 320px;
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: hidden;
    }

    .support-chat-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .support-chat-header-text {
        flex: 1;
        min-width: 0;
    }

    .support-chat-title {
        margin: 0;
        color: #fff;
        font-size: 1rem;
        font-weight: 900;
    }

    .support-chat-sub {
        margin: 2px 0 0;
        color: var(--text-muted);
        font-size: 0.75rem;
    }

    .support-chat-matrix-hint {
        margin: 6px 0 0;
        color: #f59e0b;
        font-size: 0.68rem;
        line-height: 1.35;
    }

    .support-chat-header-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .support-chat-live {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 10px;
        border-radius: 999px;
        background: var(--cyan-soft);
        color: var(--cyan);
        font-size: 0.68rem;
        font-weight: 800;
    }

    .support-chat-live-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--cyan);
    }

    .support-chat-back {
        width: 32px;
        height: 32px;
        border: none;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.06);
        color: var(--text-muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .support-chat-back:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
    }

    .support-chat-body {
        flex: 1;
        min-height: 0;
        position: relative;
        background: #1c1c1c;
    }

    .support-chat-loading {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(28, 28, 28, 0.85);
        z-index: 2;
    }

  .support-chat-loading[hidden] {
        display: none !important;
    }

    .support-chat-spinner {
        width: 28px;
        height: 28px;
        border: 3px solid rgba(0, 188, 212, 0.2);
        border-top-color: var(--cyan);
        border-radius: 50%;
        animation: support-spin 0.7s linear infinite;
    }

    @keyframes support-spin {
        to { transform: rotate(360deg); }
    }

    .support-chat-messages {
        height: 100%;
        overflow-y: auto;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

  .support-chat-messages :global(.support-chat-empty) {
        margin: auto;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.88rem;
        line-height: 1.45;
        padding: 0 12px;
    }

    .support-chat-messages :global(.support-msg-row) {
        display: flex;
        flex-direction: column;
        gap: 4px;
        max-width: 82%;
    }

    .support-chat-messages :global(.support-msg-row.is-mine) {
        align-self: flex-end;
        align-items: flex-end;
    }

    .support-chat-messages :global(.support-msg-row.is-other) {
        align-self: flex-start;
        align-items: flex-start;
    }

    .support-chat-messages :global(.support-msg-label) {
        color: var(--cyan);
        font-size: 0.62rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-left: 4px;
    }

    .support-chat-messages :global(.support-msg-bubble) {
        border-radius: 18px;
        padding: 10px 14px;
    }

    .support-chat-messages :global(.support-msg-row.is-mine .support-msg-bubble) {
        background: var(--cyan);
        border-bottom-right-radius: 6px;
    }

    .support-chat-messages :global(.support-msg-row.is-mine .support-msg-bubble p) {
        color: #000;
        font-weight: 600;
    }

    .support-chat-messages :global(.support-msg-row.is-other .support-msg-bubble) {
        background: #383838;
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-bottom-left-radius: 6px;
    }

    .support-chat-messages :global(.support-msg-bubble p) {
        margin: 0;
        font-size: 0.94rem;
        line-height: 1.4;
        color: #fff;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .support-chat-messages :global(.support-msg-time) {
        font-size: 0.62rem;
        color: #666;
        margin: 0 4px;
    }

    .support-chat-input-row {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        padding: 8px 10px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        background: #242424;
    }

    .support-chat-input {
        flex: 1;
        min-height: 44px;
        max-height: 88px;
        resize: none;
        border-radius: 22px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: #1a1a1a;
        color: white;
        font-family: inherit;
        font-size: 0.94rem;
        line-height: 1.35;
        padding: 11px 14px;
        outline: none;
    }

    .support-chat-input:focus {
        border-color: rgba(0, 188, 212, 0.35);
    }

    .support-chat-send {
        width: 44px;
        height: 44px;
        flex-shrink: 0;
        border: none;
        border-radius: 50%;
        background: var(--cyan);
        color: #000;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.2s ease;
    }

    .support-chat-send:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }
</style>

<script>
    import { initSupportChatPanel } from '../lib/supportChatPanel';

    type PanelApi = ReturnType<typeof initSupportChatPanel>;
    let panelCleanup: (() => void) | null = null;

    function mountSupportPanel() {
        const root = document.querySelector<HTMLElement>('[data-support-panel]');
        if (!root) return;

        panelCleanup?.();

        const api = initSupportChatPanel(root, {
            loginPath: '/login?redirect=' + encodeURIComponent('/kontakt?mode=chat'),
        });
        panelCleanup = api.destroy;

        document.dispatchEvent(
            new CustomEvent('support-chat-ready', { detail: { api, root } }),
        );
    }

    mountSupportPanel();
    document.addEventListener('astro:page-load', mountSupportPanel);
</script>
