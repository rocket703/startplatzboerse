    function initEventDatePicker() {
        const hiddenInput = dateInput;
        const trigger = document.getElementById('event-date-trigger');
        const display = document.getElementById('event-date-display');
        const modal = document.getElementById('date-picker-modal');
        const backdrop = document.getElementById('date-modal-backdrop');
        const grid = document.getElementById('date-grid');
        const monthLabel = document.getElementById('date-month-label');
        const btnPrev = document.getElementById('date-prev');
        const btnNext = document.getElementById('date-next');
        const btnClose = document.getElementById('date-modal-close');

        if (!hiddenInput || !trigger || !display || !modal || !grid || !monthLabel) return;

        let viewDate = new Date();
        viewDate.setDate(1);

        const minDate = new Date();
        minDate.setHours(0, 0, 0, 0);
        const maxDate = new Date(minDate);
        maxDate.setFullYear(maxDate.getFullYear() + 3);

        function formatDisplay(iso: string) {
            if (!iso) return 'Datum wählen';
            return new Date(iso + 'T12:00:00').toLocaleDateString('de-DE', {
                weekday: 'short',
                day: 'numeric',
                month: 'long',
                year: 'numeric',
            });
        }

        function isoFromParts(y: number, m: number, d: number) {
            return `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        }

        function renderCalendar() {
            const year = viewDate.getFullYear();
            const month = viewDate.getMonth();
            monthLabel.textContent = viewDate.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });

            const firstDay = new Date(year, month, 1);
            const startWeekday = (firstDay.getDay() + 6) % 7;
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            grid.innerHTML = '';

            for (let i = 0; i < startWeekday; i++) {
                const spacer = document.createElement('span');
                spacer.className = 'date-cell is-empty';
                grid.appendChild(spacer);
            }

            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const selectedIso = hiddenInput.value;

            for (let day = 1; day <= daysInMonth; day++) {
                const cellDate = new Date(year, month, day);
                const iso = isoFromParts(year, month, day);
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'date-cell';
                btn.textContent = String(day);

                const isPast = cellDate < minDate;
                const isTooFar = cellDate > maxDate;
                if (isPast || isTooFar) btn.classList.add('is-disabled');
                if (iso === selectedIso) btn.classList.add('is-selected');
                if (cellDate.getTime() === today.getTime()) btn.classList.add('is-today');

                btn.addEventListener('click', () => {
                    if (isPast || isTooFar) return;
                    hiddenInput.value = iso;
                    display.textContent = formatDisplay(iso);
                    trigger.classList.add('has-value');
                    closeModal();
                });
                grid.appendChild(btn);
            }
        }

        function openModal() {
            if (hiddenInput.value) {
                const [y, m] = hiddenInput.value.split('-').map(Number);
                viewDate = new Date(y, m - 1, 1);
            } else {
                viewDate = new Date();
                viewDate.setDate(1);
            }
            modal.hidden = false;
            document.body.classList.add('date-modal-open');
            renderCalendar();
        }

        function closeModal() {
            modal.hidden = true;
            document.body.classList.remove('date-modal-open');
        }

        trigger.addEventListener('click', openModal);
        backdrop?.addEventListener('click', closeModal);
        btnClose?.addEventListener('click', closeModal);
        btnPrev?.addEventListener('click', () => {
            viewDate.setMonth(viewDate.getMonth() - 1);
            renderCalendar();
        });
        btnNext?.addEventListener('click', () => {
            viewDate.setMonth(viewDate.getMonth() + 1);
            renderCalendar();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !modal.hidden) closeModal();
        });

        if (hiddenInput.value) {
            display.textContent = formatDisplay(hiddenInput.value);
            trigger.classList.add('has-value');
        }
    }

