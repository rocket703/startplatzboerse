---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import FeedbackBanner from '../components/FeedbackBanner.astro';
import '../styles/inserieren-form.css';
---

<Layout title="Startplatz inserieren - Startplatzbörse">
    <main class="page-wrapper">
        <div class="form-wrapper">
            <div class="form-card">

                <!-- PROGRESS BAR (4 Schritte) -->
                <div class="progress-bar">
                    <div class="step active" id="step-dot-1">1</div>
                    <div class="line" id="line-1"></div>
                    <div class="step" id="step-dot-2">2</div>
                    <div class="line" id="line-2"></div>
                    <div class="step" id="step-dot-3">3</div>
                    <div class="line" id="line-3"></div>
                    <div class="step" id="step-dot-4">4</div>
                </div>

                <!-- ───── SCHRITT 1: AUTH (unverändert) ───── -->
                <div id="auth-section" class="form-step">
                    <header class="form-header">
                        <span class="step-badge">Schritt 1 · Anmeldung</span>
                        <h1 class="form-title" id="auth-heading">Wer bist du?</h1>
                        <p class="form-lead">Wir brauchen kurz deine E-Mail für die Verifizierung.</p>
                    </header>

                    <div id="auth-step-email" class="form-panel">
                        <div class="field">
                            <label class="field-label" for="email">E-Mail Adresse</label>
                            <input class="field-input" type="email" id="email" placeholder="deine@mail.de" maxlength="50">
                        </div>
                        <button type="button" class="btn-primary" id="btn-send-otp">Code anfordern</button>
                    </div>

                    <div id="auth-step-otp" class="form-panel" style="display: none;">
                        <div class="field">
                            <label class="field-label" for="otp-code">6-stelliger Code</label>
                            <input class="field-input otp-input" type="text" id="otp-code" placeholder="123456" maxlength="6"
                                oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                        </div>
                        <button type="button" class="btn-primary" id="btn-verify-otp">Identität bestätigen</button>
                    </div>

                    <div id="auth-step-profile" class="form-panel profile" style="display: none;">
                        <div class="field">
                            <label class="field-label" for="vorname">Vorname</label>
                            <input class="field-input" type="text" id="vorname" placeholder="Dein Vorname" maxlength="30">
                        </div>
                        <div class="field">
                            <label class="field-label" for="nachname">Nachname</label>
                            <input class="field-input" type="text" id="nachname" placeholder="Dein Nachname" maxlength="30">
                        </div>
                        <div class="field">
                            <label class="field-label" for="nickname">Dein Nickname</label>
                            <input class="field-input" type="text" id="nickname" placeholder="3–20 Zeichen" maxlength="20">
                        </div>
                        <div class="checkbox-row">
                            <input type="checkbox" id="agb-consent" />
                            <label for="agb-consent" class="checkbox-row-label">
                                Ich stimme den <a href="/agb" class="text-link" target="_blank" rel="noopener">AGB</a> zu.
                            </label>
                        </div>
                        <button type="button" class="btn-primary" id="btn-save-profile">Profil speichern & weiter</button>
                    </div>
                </div>

                <!-- ───── FORMULAR (Schritte 2–4) ───── -->
                <form id="listing-form" style="display: none;" novalidate>

                    <!-- SCHRITT 2: Event-Info + Distanz -->
                    <div id="listing-step-2" class="form-step">
                        <header class="form-header">
                            <span class="step-badge">Schritt 2 · Event</span>
                            <h2 class="form-title">Das Event</h2>
                            <p class="form-lead">Grundlegende Informationen zum Event.</p>
                        </header>

                        <div class="form-panel">
                        <div class="field">
                        <label class="field-label" for="category">Sportart</label>
                        <select required class="field-input field-select" id="category" name="category">
                            <option value="" disabled selected>Bitte wählen...</option>
                            <option value="Laufen">Laufen</option>
                            <option value="Radrennen">Radrennen</option>
                            <option value="Triathlon">Triathlon</option>
                            <option value="Hyrox">Hyrox</option>
                        </select>
                        </div>

                        <div class="field">
                        <label class="field-label" for="event_name">Name des Events</label>
                        <input required class="field-input" type="text" id="event_name" name="event_name" placeholder="z.B. Berlin Marathon" maxlength="100">
                        </div>

                        <div class="field">
                        <label class="field-label">Datum des Events</label>
                        <button type="button" class="field-input date-trigger" id="event-date-trigger" aria-haspopup="dialog" aria-controls="date-picker-modal">
                            <span id="event-date-display">Datum wählen</span>
                            <i class="fa-regular fa-calendar" aria-hidden="true"></i>
                        </button>
                        <input type="hidden" id="event_date" name="event_date" required>
                        </div>

                        <!-- Distanz (Pills wie App; Ultra/Trail als Spezialisierung) -->
                        <input type="hidden" id="distance-select" name="distance" value="" />

                        <div id="laufen-special-section" class="laufen-special-section field" hidden>
                            <label class="field-label">Spezialisierung</label>
                            <p class="field-hint laufen-special-hint">Optional — für Ultra- oder Trail-Events mit erweiterten Angaben.</p>
                            <div class="special-list">
                                <button type="button" class="special-row" data-special="Ultra">
                                    <span class="special-row-body">
                                        <span class="special-row-title">Ultra</span>
                                        <span class="special-row-sub">Distanz- oder Zeitläufe ab Marathon</span>
                                    </span>
                                    <span class="special-row-chevron" aria-hidden="true">›</span>
                                </button>
                                <button type="button" class="special-row" data-special="Trail">
                                    <span class="special-row-body">
                                        <span class="special-row-title">Trail</span>
                                        <span class="special-row-sub">Geländelauf mit Höhenmetern</span>
                                    </span>
                                    <span class="special-row-chevron" aria-hidden="true">›</span>
                                </button>
                            </div>
                            <button type="button" class="special-remove" id="btn-remove-special" hidden>Spezialisierung entfernen</button>
                        </div>

                        <div id="distance-pills-wrapper" class="field">
                            <label class="field-label" id="distance-pills-label">Distanz / Kategorie</label>
                            <p class="field-hint" id="distance-pills-muted" hidden>Deaktiviert, solange Ultra oder Trail gewählt ist.</p>
                            <div id="distance-pills" class="pill-scroll" role="group" aria-labelledby="distance-pills-label"></div>
                        </div>

                        <div id="custom-distance-wrapper" class="field" style="display: none;">
                            <label class="field-label" id="custom-distance-label">Kilometer (km)</label>
                            <input class="field-input" type="number" id="custom-distance" name="distance_km" placeholder="z.B. 65" step="0.1" min="0.1" max="5000" inputmode="decimal">
                        </div>

                        <div class="field-row tri-dist-row" id="custom-triathlon-wrapper" style="display: none;">
                            <div class="field">
                                <label class="field-label">Schwimmen (km)</label>
                                <input class="field-input" type="number" id="custom-swim" name="swim_dist" placeholder="z.B. 2" step="0.1" min="0.1" max="5000" inputmode="decimal">
                            </div>
                            <div class="field">
                                <label class="field-label">Rad (km)</label>
                                <input class="field-input" type="number" id="custom-bike" name="bike_dist" placeholder="z.B. 60" step="0.1" min="0.1" max="5000" inputmode="decimal">
                            </div>
                            <div class="field">
                                <label class="field-label">Laufen (km)</label>
                                <input class="field-input" type="number" id="custom-run" name="run_dist" placeholder="z.B. 15" step="0.1" min="0.1" max="5000" inputmode="decimal">
                            </div>
                        </div>

                        <div class="field">
                        <label class="field-label" for="event_url">Veranstalter-Homepage (optional)</label>
                        <input class="field-input" type="url" id="event_url" name="event_url" placeholder="https://www.berlin-marathon.de" maxlength="255">
                        </div>

                        <button type="button" class="btn-primary" id="btn-step2-next">Weiter</button>
                        </div>
                    </div>

                    <!-- SCHRITT 2b: Ultra / Trail Details (wie App) -->
                    <div id="listing-step-2b" class="form-step" style="display: none;">
                        <header class="form-header">
                            <span class="step-badge">Schritt 2 · Details</span>
                            <h2 class="form-title" id="run-special-heading">Ultra — Details</h2>
                            <p class="form-lead" id="run-special-subtitle">Distanz oder Dauer, optional Cut-off und Untergrund.</p>
                        </header>

                        <div class="form-panel">
                        <div id="run-ultra-wrapper" class="run-detail-panel">
                            <label class="field-label" for="ultra-format">Art des Ultralaufs</label>
                            <select class="field-input field-select" id="ultra-format">
                                <option value="distance">Distanz-basiert</option>
                                <option value="time">Zeit-basiert</option>
                                <option value="backyard">Backyard Ultra</option>
                            </select>
                            <div class="field-row">
                                <div class="field">
                                    <label class="field-label" id="ultra-value-label">Distanz / Stunden</label>
                                    <input class="field-input" type="number" id="ultra-value" step="0.1" min="0.1" placeholder="z.B. 100" inputmode="decimal">
                                </div>
                                <div class="field" id="ultra-unit-wrap">
                                    <label class="field-label" for="ultra-unit">Einheit</label>
                                    <select class="field-input field-select" id="ultra-unit">
                                        <option value="km">Kilometer</option>
                                        <option value="mi">Meilen</option>
                                    </select>
                                </div>
                            </div>
                            <div class="field">
                            <label class="field-label" for="ultra-cutoff">Cut-off-Zeit (optional)</label>
                            <input class="field-input" type="text" id="ultra-cutoff" placeholder="z. B. 12 oder 6:30" maxlength="8" inputmode="decimal">
                            </div>
                            <div class="field">
                            <label class="field-label" for="ultra-surface">Untergrund / Modus</label>
                            <select class="field-input field-select" id="ultra-surface">
                                <option value="road">Straße / Asphalt</option>
                                <option value="track">Bahn (400 m-Schleife)</option>
                                <option value="loop">Rundkurs (flach, gemischt)</option>
                            </select>
                            </div>
                            <div class="checkbox-row">
                                <input type="checkbox" id="ultra-quali" />
                                <label for="ultra-quali" class="checkbox-row-label">Qualifikationsnachweis erforderlich</label>
                            </div>
                            <input class="field-input" type="text" id="ultra-quali-note" placeholder="z.B. Marathon-Finisher unter 4 h" maxlength="120" hidden>
                            <div class="field">
                            <span class="field-label">Zusatzleistungen (optional)</span>
                            <div class="check-stack run-check-group">
                                <label><input type="checkbox" name="ultra-extra" value="depot" /> Eigenverpflegung-Depot</label>
                                <label><input type="checkbox" name="ultra-extra" value="medal_engraving" /> Medaillengravur</label>
                                <label><input type="checkbox" name="ultra-extra" value="finisher_shirt" /> Finisher-Shirt</label>
                            </div>
                            </div>
                        </div>

                        <div id="run-trail-wrapper" class="run-detail-panel" hidden>
                            <div class="field">
                            <label class="field-label" for="trail-band">Distanz-Kategorie</label>
                            <select class="field-input field-select" id="trail-band">
                                <option value="sprint">Trail-Sprint (&lt; 15 km)</option>
                                <option value="medium">Trail / Medium (15–41 km)</option>
                                <option value="ultra_trail">Ultra-Trail (≥ 42 km)</option>
                            </select>
                            </div>
                            <div class="field-row">
                                <div class="field">
                                    <label class="field-label" for="trail-km">Strecke (km)</label>
                                    <input class="field-input" type="number" id="trail-km" step="0.1" min="0.1" placeholder="30" inputmode="decimal">
                                </div>
                                <div class="field">
                                    <label class="field-label" for="trail-hm-plus">Hm+ (Aufstieg)</label>
                                    <input class="field-input" type="number" id="trail-hm-plus" min="0" placeholder="2000" inputmode="numeric">
                                </div>
                            </div>
                            <div class="field">
                            <label class="field-label" for="trail-hm-minus">Hm− Abstieg (optional)</label>
                            <input class="field-input" type="number" id="trail-hm-minus" min="0" placeholder="z.B. Downhill" inputmode="numeric">
                            </div>
                            <div class="field-row">
                                <div class="field">
                                    <label class="field-label" for="trail-itra">ITRA-Punkte</label>
                                    <select class="field-input field-select" id="trail-itra">
                                        <option value="">Keine Angabe</option>
                                        <option value="0">ITRA 0</option>
                                        <option value="1">ITRA 1</option>
                                        <option value="2">ITRA 2</option>
                                        <option value="3">ITRA 3</option>
                                        <option value="4">ITRA 4</option>
                                        <option value="5">ITRA 5</option>
                                        <option value="6">ITRA 6</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label class="field-label" for="trail-utmb">UTMB-Index</label>
                                    <select class="field-input field-select" id="trail-utmb">
                                        <option value="">Keine Angabe</option>
                                        <option value="20K">UTMB 20K</option>
                                        <option value="50K">UTMB 50K</option>
                                        <option value="100K">UTMB 100K</option>
                                        <option value="100M">UTMB 100M</option>
                                    </select>
                                </div>
                            </div>
                            <div class="field">
                            <span class="field-label">Pflichtausrüstung</span>
                            <div class="check-stack run-check-group">
                                <label><input type="checkbox" name="trail-gear" value="none" /> Keine</label>
                                <label><input type="checkbox" name="trail-gear" value="basic" /> Basis</label>
                                <label><input type="checkbox" name="trail-gear" value="extended" /> Erweitert</label>
                            </div>
                            </div>
                            <div class="field">
                            <label class="field-label" for="trail-terrain">Gelände / Technik</label>
                            <select class="field-input field-select" id="trail-terrain">
                                <option value="easy">Leicht (Waldwege, breite Pfade)</option>
                                <option value="moderate">Moderat (Singletrails, Wurzeln)</option>
                                <option value="technical">Technisch / Alpin</option>
                            </select>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-primary" id="btn-step2b-next">Weiter</button>
                            <button type="button" class="btn-secondary" id="btn-step2b-back">Zurück</button>
                        </div>
                        </div>
                    </div>

                    <!-- SCHRITT 3: Nur Ort -->
                    <div id="listing-step-3" class="form-step" style="display: none;">
                        <header class="form-header">
                            <span class="step-badge">Schritt 3 · Ort</span>
                            <h2 class="form-title">Veranstaltungsort</h2>
                            <p class="form-lead">Wo findet das Event statt?</p>
                        </header>

                        <div class="form-panel">
                        <div class="field">
                        <label class="field-label" for="street">Straße & Hausnummer (optional)</label>
                        <input class="field-input" type="text" id="street" name="street" placeholder="z.B. Unter den Linden 1" maxlength="100">
                        </div>

                        <div class="field-row">
                            <div class="field">
                                <label class="field-label" for="plz">Postleitzahl</label>
                                <input required class="field-input" type="text" id="plz" name="plz" placeholder="z. B. 10115" maxlength="12" autocomplete="postal-code">
                            </div>
                            <div class="field">
                                <label class="field-label" for="location">Ort des Events</label>
                                <input required class="field-input" type="text" id="location" name="location" list="location-list" placeholder="Ort eingeben" autocomplete="off">
                                <datalist id="location-list"></datalist>
                                <p id="location-hint" class="field-hint" hidden>Ort automatisch vorgeschlagen – bitte bei Bedarf anpassen.</p>
                            </div>
                        </div>

                        <button type="button" class="btn-primary" id="btn-step3-next">Weiter</button>
                        </div>
                    </div>

                    <!-- SCHRITT 4: Preis & Bestätigung -->
                    <div id="listing-step-4" class="form-step" style="display: none;">
                        <header class="form-header">
                            <span class="step-badge">Schritt 4 · Veröffentlichen</span>
                            <h2 class="form-title">Preis & Details</h2>
                            <p class="form-lead">Fast geschafft! Noch Preis und Beschreibung.</p>
                        </header>

                        <div class="form-panel">
                        <div class="field">
                        <label class="field-label" for="price">Dein Preis (in €)</label>
                        <div class="price-input-wrap">
                            <input required class="field-input" type="number" name="price" id="price" placeholder="50" min="1" max="9999">
                            <span class="price-suffix">€</span>
                        </div>
                        <div class="pill-row price-type-row">
                            <label class="choice-pill">
                                <input type="radio" name="price_type" value="fixed" checked />
                                <span>Festpreis</span>
                            </label>
                            <label class="choice-pill">
                                <input type="radio" name="price_type" value="vb" />
                                <span>VB</span>
                            </label>
                        </div>
                        </div>

                        <div class="field">
                        <label class="field-label" for="description">Beschreibung (optional)</label>
                        <textarea
                            class="field-input field-textarea"
                            id="description"
                            name="description"
                            placeholder="Z.B. Startplatz inklusive Ummeldegebühr, Startblock A..."
                            rows="4"
                            maxlength="500"
                        ></textarea>
                        <div id="char-count" class="char-count">0 / 500 Zeichen</div>
                        </div>

                        <div class="summary-box" id="summary-box"></div>

                        <div class="checkbox-row confirm-row">
                            <input type="checkbox" required id="confirm-transfer">
                            <label for="confirm-transfer" class="checkbox-row-label">Ich bestätige, dass ich die Ummeldung vorab mit dem Veranstalter geklärt habe.</label>
                        </div>

                        <button class="btn-primary" type="submit" id="btn-final">Inserat jetzt veröffentlichen</button>
                        </div>
                    </div>

                </form>

                <FeedbackBanner id="error-msg" />

            </div>
        </div>
    </main>
    <!-- Datumsauswahl (dark, wie App) -->
    <div id="date-picker-modal" class="date-modal" hidden>
        <div class="date-modal-backdrop" id="date-modal-backdrop"></div>
        <div class="date-modal-panel" role="dialog" aria-modal="true" aria-labelledby="date-month-label">
            <div class="date-modal-header">
                <button type="button" class="date-nav" id="date-prev" aria-label="Vorheriger Monat">‹</button>
                <span class="date-month-label" id="date-month-label"></span>
                <button type="button" class="date-nav" id="date-next" aria-label="Nächster Monat">›</button>
            </div>
            <div class="date-weekdays" aria-hidden="true">
                <span>Mo</span><span>Di</span><span>Mi</span><span>Do</span><span>Fr</span><span>Sa</span><span>So</span>
            </div>
            <div class="date-grid" id="date-grid"></div>
            <button type="button" class="btn-secondary date-modal-close" id="date-modal-close">Schließen</button>
        </div>
    </div>

    <Footer />
</Layout>

<script>
    import { createClient } from '@supabase/supabase-js';
    import {
        normalizeUrl,
        normalizePostalCode,
        sanitizePostalCodeInput,
        validateEmail,
        validateListingStep2,
        validateListingStep3,
        validateOtp,
        validateOptionalUrl,
        validatePrice,
        validateProfile,
        type ListingStep2Input,
    } from '../lib/listing-form-validation';
    import {
        collectPlaceOptions,
        lookupPlacesByPostalCode,
        pickSuggestedCity,
    } from '../lib/postal-lookup';
    import { hideFeedback, showFeedbackError, showFeedbackSuccess } from '../lib/feedback-banner';
    import {
        LISTING_DISTANCE_OPTIONS,
        LAUFEN_SPECIAL_DISTANCES,
        standardDistancesForCategory,
        type LaufenSpecial,
    } from '../constants/listingOptions';
    import { buildTrailListing, buildUltraListing, validateTrailForm, validateUltraForm } from '../lib/runListingBuild';
    import { readTrailFormFromDom, readUltraFormFromDom, syncUltraUnitField } from '../lib/runListingFormDom';

    const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    // --- DOM ELEMENTE ---
    const authSection       = document.getElementById('auth-section');
    const authStepEmail     = document.getElementById('auth-step-email');
    const authStepOtp       = document.getElementById('auth-step-otp');
    const authStepProfile   = document.getElementById('auth-step-profile');
    const listingForm       = document.getElementById('listing-form');
    const errorDisplay      = document.getElementById('error-msg');

    const inputEmail  = document.getElementById('email') as HTMLInputElement;
    const inputOtp    = document.getElementById('otp-code') as HTMLInputElement;

    const categorySelect  = document.getElementById('category') as HTMLSelectElement;
    const distanceSelect  = document.getElementById('distance-select') as HTMLInputElement;
    const distancePills = document.getElementById('distance-pills');
    const distancePillsWrapper = document.getElementById('distance-pills-wrapper');
    const distancePillsLabel = document.getElementById('distance-pills-label');
    const distancePillsMuted = document.getElementById('distance-pills-muted');
    const laufenSpecialSection = document.getElementById('laufen-special-section');
    const btnRemoveSpecial = document.getElementById('btn-remove-special');
    const runSpecialHeading = document.getElementById('run-special-heading');
    const runSpecialSubtitle = document.getElementById('run-special-subtitle');
    const customSingleWrapper = document.getElementById('custom-distance-wrapper');
    const customTriWrapper    = document.getElementById('custom-triathlon-wrapper');
    const customSingleInput   = document.getElementById('custom-distance') as HTMLInputElement;
    const customSwim = document.getElementById('custom-swim') as HTMLInputElement;
    const customBike = document.getElementById('custom-bike') as HTMLInputElement;
    const customRun  = document.getElementById('custom-run') as HTMLInputElement;
    const ultraWrapper = document.getElementById('run-ultra-wrapper');
    const trailWrapper = document.getElementById('run-trail-wrapper');
    const ultraQuali = document.getElementById('ultra-quali') as HTMLInputElement;
    const ultraQualiNote = document.getElementById('ultra-quali-note') as HTMLInputElement;
    const ultraFormat = document.getElementById('ultra-format') as HTMLSelectElement;

    const dateInput    = document.getElementById('event_date') as HTMLInputElement;
    const plzInput     = document.getElementById('plz') as HTMLInputElement;
    const locationInput = document.getElementById('location') as HTMLInputElement;
    const locationList  = document.getElementById('location-list');
    const locationHint  = document.getElementById('location-hint');
    const descArea     = document.getElementById('description') as HTMLTextAreaElement;
    const charDisplay  = document.getElementById('char-count');

    let lastAutoLocation: string | null = null;
    let postalLookupTimer: ReturnType<typeof setTimeout> | null = null;
    let runSpecial: LaufenSpecial | null = null;

    const RUN_SPECIAL_COPY: Record<LaufenSpecial, { title: string; subtitle: string }> = {
        Ultra: {
            title: 'Ultra — Details',
            subtitle: 'Distanz oder Dauer, optional Cut-off und Untergrund.',
        },
        Trail: {
            title: 'Trail — Details',
            subtitle: 'Kilometer, Höhenmeter, Gelände und Ausrüstung.',
        },
    };

    function showError(msg: string) {
        showFeedbackError(errorDisplay, msg);
    }
    function hideError() {
        hideFeedback(errorDisplay);
    }

    function readStep2Input(): ListingStep2Input {
        const category = categorySelect?.value ?? '';
        const distance = getDistanceValue();
        const base: ListingStep2Input = {
            category,
            eventName: (document.querySelector('[name="event_name"]') as HTMLInputElement)?.value ?? '',
            eventDate: dateInput?.value ?? '',
            distance,
            eventUrl: (document.querySelector('[name="event_url"]') as HTMLInputElement)?.value ?? '',
            customKm: customSingleInput?.value ?? '',
