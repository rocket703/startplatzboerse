listingForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const btn = document.getElementById('btn-final') as HTMLButtonElement;
    if (btn) {
        btn.disabled = true;
        btn.textContent = 'Wird veröffentlicht...';
    }

    try {
        const priceInput = document.getElementById('price') as HTMLInputElement;
        const confirmCheckbox = document.getElementById('confirm-transfer') as HTMLInputElement;

        const step2Error = validateListingStep2(readStep2Input());
        if (step2Error) throw new Error(step2Error);

        const plzVal = plzInput?.value.trim() ?? '';
        const locationValCheck = locationInput?.value.trim() ?? '';
        const step3Error = validateListingStep3(plzVal, locationValCheck);
        if (step3Error) throw new Error(step3Error);

        const priceError = validatePrice(priceInput?.value ?? '');
        if (priceError) throw new Error(priceError);

        if (!confirmCheckbox?.checked) {
            throw new Error('Bitte bestätige die Ummeldung mit dem Veranstalter.');
        }

        const { data: { user } } = await supabase.auth.getUser();
        if (!user) throw new Error('Sitzung abgelaufen. Bitte neu anmelden.');

        // Profildaten holen
        const { data: profile } = await supabase
            .from('profiles')
            .select('first_name, last_name, nickname')
            .eq('id', user.id)
            .single();

        // Formulardaten holen
        const formData = new FormData(e.target as HTMLFormElement);
        const vals = Object.fromEntries(formData);
        const eventUrlRaw = (vals.event_url as string) || '';
        const urlError = validateOptionalUrl(eventUrlRaw);
        if (urlError) throw new Error(urlError);
        const normalizedEventUrl = normalizeUrl(eventUrlRaw);

        const category = categorySelect.value;
        const locationVal = locationInput?.value.trim();

        // Geocoding
        let finalLat = null, finalLng = null;
        try {
            const searchQuery = encodeURIComponent(`${normalizePostalCode(plzVal)} ${locationVal}`);
            const geoRes = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${searchQuery}&limit=1`);
            const geoData = await geoRes.json();
            if (geoData?.length > 0) {
                finalLat = parseFloat(geoData[0].lat);
                finalLng = parseFloat(geoData[0].lon);
            }
        } catch (geoErr) {
            console.warn('Geocoding fehlgeschlagen', geoErr);
        }

        // === OPTIMIERTE DISTANZ-LOGIK FÜR DIE FILTERUNG ===
        let displayDist = (vals.distance as string) || 'Freie Distanz';
        let filterKm = 0;
        let elevationGainM: number | null = null;
        let elevationLossM: number | null = null;
        let listingMeta: Record<string, unknown> = {};
        let swimDist: number | null = null;
        let bikeDist: number | null = null;
        let runDist: number | null = null;

        if (category === 'Laufen' && displayDist === 'Ultra') {
            const ultraErr = validateUltraForm(readUltraFormFromDom());
            if (ultraErr) throw new Error(ultraErr);
            const built = buildUltraListing(readUltraFormFromDom());
            displayDist = built.displayDist;
            filterKm = built.distance_km;
            elevationGainM = built.elevation_gain_m;
            elevationLossM = built.elevation_loss_m;
            listingMeta = built.listing_meta as Record<string, unknown>;
        } else if (category === 'Laufen' && displayDist === 'Trail') {
            const trailErr = validateTrailForm(readTrailFormFromDom());
            if (trailErr) throw new Error(trailErr);
            const built = buildTrailListing(readTrailFormFromDom());
            displayDist = built.displayDist;
            filterKm = built.distance_km;
            elevationGainM = built.elevation_gain_m;
            elevationLossM = built.elevation_loss_m;
            listingMeta = built.listing_meta as Record<string, unknown>;
        } else if (displayDist === 'Freie Distanz') {
            if (category === 'Triathlon') {
                swimDist = vals.swim_dist ? parseFloat(vals.swim_dist as string) : null;
                bikeDist = vals.bike_dist ? parseFloat(vals.bike_dist as string) : null;
                runDist = vals.run_dist ? parseFloat(vals.run_dist as string) : null;

                const triParts = [];
                if (swimDist !== null) triParts.push(`Schwimmen ${swimDist} km`);
                if (bikeDist !== null) triParts.push(`Rad ${bikeDist} km`);
                if (runDist  !== null) triParts.push(`Laufen ${runDist} km`);
                if (triParts.length > 0) {
                    displayDist = `Freie Distanz – ${triParts.join(' · ')}`;
                    filterKm = [swimDist, bikeDist, runDist].filter((n) => n !== null).reduce((sum, n) => sum + (n as number), 0);
                }
            } else {
                const customKm = vals.distance_km ? parseFloat(vals.distance_km as string) : 0;
                if (customKm > 0) {
                    displayDist = `Freie Distanz (${customKm} km)`;
                    filterKm = customKm;
                }
            }
        } else {
            // Mapping für Standarddistanzen, um Suchfelder numerisch zu füttern
            switch (displayDist) {
                // Laufen
                case '5 km': filterKm = 5; break;
                case '10 km': filterKm = 10; break;
                case '21,1 km Halbmarathon': filterKm = 21.1; break;
                case '42,2 km Marathon': filterKm = 42.2; break;
                
                // Triathlon Standard-Distanzen splitten
                case 'Sprint (0,75/20/5 km)':
                    swimDist = 0.75; bikeDist = 20; runDist = 5;
                    filterKm = 25.75;
                    break;
                case 'Olympisch (1,5/40/10 km)':
                    swimDist = 1.5; bikeDist = 40; runDist = 10;
                    filterKm = 51.5;
                    break;
                case '70.3 Mitteldistanz (1,9/90/21 km)':
                    swimDist = 1.9; bikeDist = 90; runDist = 21;
                    filterKm = 112.9;
                    break;
                case '140.6 Langdistanz (3,8/180/42 km)':
                    swimDist = 3.8; bikeDist = 180; runDist = 42;
                    filterKm = 225.8;
                    break;
                
                // Hyrox oder andere Standard-Events ohne feste Strecken-KM
                default:
                    filterKm = 0; 
                    break;
            }
        }

        const insertRow: Record<string, unknown> = {
            user_id: user.id,
            seller_email: user.email,
            vorname: profile?.first_name || '',
            nachname: profile?.last_name || '',
            category,
            event_name: vals.event_name,
            description: vals.description || '',
            distance: displayDist,
            distance_km: filterKm,
            elevation_gain_m: elevationGainM,
            elevation_loss_m: elevationLossM,
            swim_dist: swimDist,
            bike_dist: bikeDist,
            run_dist: runDist,
            event_date: vals.event_date,
            street: vals.street || null,
            event_url: normalizedEventUrl || null,
            plz: normalizePostalCode(plzVal),
            location: locationVal,
            lat: finalLat,
            lng: finalLng,
            price: parseFloat(vals.price as string),
            price_type: vals.price_type === 'vb' ? 'vb' : 'fixed',
            status: 'active'
        };
        if ((listingMeta as { run?: unknown })?.run) {
            insertRow.listing_meta = listingMeta;
        }

        const { error } = await supabase.from('listings').insert([insertRow]);

        if (error) throw error;

        showFeedbackSuccess(
            errorDisplay,
            'Dein Inserat wurde veröffentlicht. Du wirst zum Dashboard weitergeleitet …'
        );

        setTimeout(() => window.location.href = '/dashboard', 1800);

    } catch (err: any) {
        console.error(err);
        showError(err.message || 'Ein unbekannter Fehler ist aufgetreten.');
        
        if (btn) {
            btn.disabled = false;
            btn.textContent = 'Inserat jetzt veröffentlichen 🚀';
        }
    }
});
