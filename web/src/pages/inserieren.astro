    function renderDistancePills(cat: string) {
        if (!distancePills) return;

        const options = cat === 'Laufen'
            ? standardDistancesForCategory(cat)
            : (LISTING_DISTANCE_OPTIONS[cat] ?? []);

        distancePills.innerHTML = options.map((dist) => `
            <button type="button" class="choice-pill dist-pill" data-dist="${dist}"><span>${dist}</span></button>
        `).join('');

        distancePills.querySelectorAll<HTMLButtonElement>('.dist-pill').forEach((pill) => {
            pill.addEventListener('click', () => {
                if (runSpecial) return;
                const dist = pill.dataset.dist || '';
                setDistanceValue(dist);
                updateDistancePillState();
                updateDistanceUI();
            });
        });

        updateDistancePillState();
    }

    function updateDistancePillState() {
        if (!distancePills) return;
        const current = getDistanceValue();
        distancePills.querySelectorAll<HTMLButtonElement>('.dist-pill').forEach((pill) => {
            const isActive = !runSpecial && pill.dataset.dist === current;
            pill.classList.toggle('active', isActive);
        });
        distancePills.classList.toggle('is-muted', !!runSpecial);
        if (distancePillsMuted) distancePillsMuted.hidden = !runSpecial;
