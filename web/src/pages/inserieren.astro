    function activateStep(n: number) {
        [1,2,3,4].forEach(i => {
            const dot  = document.getElementById(`step-dot-${i}`);
            const line = document.getElementById(`line-${i}`);
            if (dot)  dot.classList.toggle('active', i <= n);
            if (line) line.classList.toggle('active', i < n);
        });
    }

    function showListingForm() {
        if (authSection)  authSection.style.display  = 'none';
        if (listingForm)  listingForm.style.display  = 'block';
        activateStep(2);
    }

    function goToStep(step: number | '2b') {
        const show2b = step === '2b';
        const numericStep = step === '2b' ? 2 : step;

        [2, 3, 4].forEach((s) => {
            const el = document.getElementById(`listing-step-${s}`);
            if (el) el.style.display = s === numericStep && !show2b ? 'block' : 'none';
        });

        const step2b = document.getElementById('listing-step-2b');
        if (step2b) step2b.style.display = show2b ? 'block' : 'none';

        activateStep(show2b ? 2 : numericStep);
        hideError();
        document.querySelector('.form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

