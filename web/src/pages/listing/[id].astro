---
import Layout from '../../layouts/Layout.astro';
import NotFoundPage from '../../components/NotFoundPage.astro';
import { createClient } from '@supabase/supabase-js';
import { formatRunMetaDetail } from '../../lib/runListingBuild';

const { id } = Astro.params;
const { searchParams } = Astro.url;
const origin = searchParams.get('from'); 

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: item, error } = await supabase
  .from('listings')
  .select(
    'id, user_id, category, event_name, description, distance, distance_km, elevation_gain_m, elevation_loss_m, swim_dist, bike_dist, run_dist, event_date, event_url, plz, location, lat, lng, price, price_type, old_price, approved, status, created_at, listing_meta',
  )
  .eq('id', id)
  .eq('approved', true)
  .eq('status', 'active')
  .maybeSingle();

if (error) {
  console.error("Supabase Error:", error.message);
}

if (!item) {
  Astro.response.status = 404;
}

// Verkäufer-Profil laden (nur wenn Inserat existiert)
const sellerId = item?.user_id;
const { data: seller } = sellerId ? await supabase
  .from('profiles_public')
  .select('nickname, updated_at, avatar_url')
  .eq('id', sellerId)
  .maybeSingle() : { data: null };

const memberSince = seller?.updated_at
  ? new Date(seller.updated_at).toLocaleDateString('de-DE', { month: 'long', year: 'numeric' })
  : null;

const backLabel = origin === 'search' ? "← Zurück zur Suche" : "← Zurück zur Übersicht";

const pageTitle = item?.event_name ?? '';
const distanceLabel = !item ? '' : item.distance === 'Freie Distanz' ? (
  item.category === 'Triathlon' && (item.swim_dist || item.bike_dist || item.run_dist) ?
    `Freie Distanz – Schwimmen ${item.swim_dist ?? '?'} km · Rad ${item.bike_dist ?? '?'} km · Laufen ${item.run_dist ?? '?'} km` :
    item.distance_km ? `Freie Distanz (${item.distance_km} km)` :
    'Freie Distanz'
) : item.distance || 'K.A.';

const runProfileDetail = item ? formatRunMetaDetail({
  listing_meta: item.listing_meta,
  distance_km: item.distance_km,
  elevation_gain_m: item.elevation_gain_m,
  elevation_loss_m: item.elevation_loss_m,
}) : null;

const eventHost = item?.event_url
  ? (() => {
      try {
        return new URL(item.event_url).hostname.replace(/^www\./, '');
      } catch {
        return item.event_url;
      }
    })()
  : null;

type EventFact = {
  key: string;
  label: string;
  value: string;
  href?: string;
  multiline?: boolean;
};

function buildEventFacts(listing: NonNullable<typeof item>): EventFact[] {
  const facts: EventFact[] = [];

  facts.push({
    key: 'date',
    label: 'Datum',
    value: new Date(listing.event_date).toLocaleDateString('de-DE', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }),
  });

  const locationParts: string[] = [];
  if (listing.street?.trim()) locationParts.push(listing.street.trim());
  const cityLine = [listing.plz, listing.location].filter(Boolean).join(' ').trim();
  if (cityLine) locationParts.push(cityLine);
  if (locationParts.length) {
    facts.push({ key: 'location', label: 'Ort', value: locationParts.join(', ') });
  }

  const triSplit =
    listing.category === 'Triathlon' &&
    (listing.swim_dist != null || listing.bike_dist != null || listing.run_dist != null);

  if (triSplit) {
    if (listing.distance && listing.distance !== 'Freie Distanz') {
      facts.push({ key: 'distance', label: 'Format', value: listing.distance });
    }
    if (listing.swim_dist != null) {
      facts.push({ key: 'swim', label: 'Schwimmen', value: `${listing.swim_dist} km` });
    }
    if (listing.bike_dist != null) {
      facts.push({ key: 'bike', label: 'Rad', value: `${listing.bike_dist} km` });
    }
    if (listing.run_dist != null) {
      facts.push({ key: 'run', label: 'Laufen', value: `${listing.run_dist} km` });
    }
  } else {
    facts.push({ key: 'distance', label: 'Distanz', value: distanceLabel });
  }

  if (runProfileDetail) {
    facts.push({
      key: 'profile',
      label: 'Streckenprofil',
      value: runProfileDetail,
      multiline: true,
    });
  } else if (listing.elevation_gain_m != null || listing.elevation_loss_m != null) {
    const elev: string[] = [];
    if (listing.elevation_gain_m != null) elev.push(`+${listing.elevation_gain_m} hm`);
    if (listing.elevation_loss_m != null) elev.push(`−${listing.elevation_loss_m} hm`);
    facts.push({ key: 'elevation', label: 'Höhenmeter', value: elev.join(' · ') });
  }

  if (listing.event_url) {
    facts.push({
      key: 'website',
      label: 'Event-Website',
      value: eventHost ?? listing.event_url,
      href: listing.event_url,
    });
  }

  return facts;
}

const eventFacts = item ? buildEventFacts(item) : [];
const priceTypeLabel = item?.price_type === 'vb' ? 'Verhandlungsbasis' : 'Festpreis';

const seoDescription = item
  ? `Sichere dir jetzt einen Startplatz für ${item.event_name} am ${new Date(item.event_date).toLocaleDateString('de-DE')} in ${item.location}. Preis: ${item.price}€. Sicherer Kauf via Startplatzbörse.`
  : '';
---

{!item ? (
  <NotFoundPage />
) : (
<Layout
  title={pageTitle}
  description={seoDescription}
  image="/og-default.png"
  canonicalURL={`https://startplatzboerse.com/listing/${id}`}
  ogType="article"
>
    <main class="listing-page">
        <div class="container">
            <a href="/#listings" class="back-link button-style" id="dynamic-back-btn">
                {backLabel}
            </a>

            <div class="listing-layout">
                <section class="hero-card">
                    <div class="hero-top">
                        <span class="badge">{item.category}</span>
                        <div class="header-actions-right">
                            <button
                                type="button"
                                class="heart-btn"
                                data-watchlist-id={item.id}
                                aria-label="Merken"
                                aria-pressed="false"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="heart-icon" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                                </svg>
                            </button>
                            <button id="share-btn" class="share-btn" aria-label="Inserat teilen">
                                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                                Teilen
                            </button>
                        </div>
                    </div>
                    <h1 class="glow-title">{item.event_name}</h1>

                    <ul class="event-facts">
                        {eventFacts.map((fact) => (
                            <li class="event-fact">
                                <span class="fact-icon" aria-hidden="true">
                                    {fact.key === 'date' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5a2.25 2.25 0 002.25-2.25m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5a2.25 2.25 0 0121 11.25v7.5" />
                                        </svg>
                                    )}
                                    {fact.key === 'location' && (
                                        <svg viewBox="0 0 24 24" fill="currentColor">
                                            <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                                        </svg>
                                    )}
                                    {fact.key === 'distance' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                                        </svg>
                                    )}
                                    {fact.key === 'elevation' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 20l9-16 9 16H3z" />
                                        </svg>
                                    )}
                                    {fact.key === 'profile' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                                        </svg>
                                    )}
                                    {fact.key === 'swim' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12c2.25-2.25 4.5-2.25 6.75 0s4.5 2.25 6.75 0 4.5-2.25 6.75 0M2.25 17c2.25-2.25 4.5-2.25 6.75 0s4.5 2.25 6.75 0 4.5-2.25 6.75 0" />
                                        </svg>
                                    )}
                                    {fact.key === 'bike' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <circle cx="5.5" cy="17.5" r="2.5" /><circle cx="18.5" cy="17.5" r="2.5" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 17.5h2l2.5-7h4l1.5 4H18" />
                                        </svg>
                                    )}
                                    {fact.key === 'run' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 5l2 2m-8 9.5a3.5 3.5 0 117 0 3.5 3.5 0 01-7 0zM6.5 20.5l2-4.5 3 1 2.5-3" />
                                        </svg>
                                    )}
                                    {fact.key === 'website' && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253" />
                                        </svg>
                                    )}
                                </span>
                                <div class="fact-copy">
                                    <span class="fact-label">{fact.label}</span>
                                    {fact.href ? (
                                        <a class="fact-value fact-link" href={fact.href} target="_blank" rel="noopener noreferrer">
                                            {fact.value}
                                        </a>
                                    ) : fact.multiline ? (
                                        <span class="fact-value fact-multiline">{fact.value}</span>
                                    ) : (
                                        <span class="fact-value">{fact.value}</span>
                                    )}
                                </div>
                            </li>
                        ))}
                    </ul>
                </section>

                <div class="detail-lower-grid">
                    <div class="info-stack">
                        <div class="card price-card">
                            <span class="label">Preis</span>
                            <div class="price-display">
                                <span class="main-price">{item.price}€</span>
                                {item.old_price && <span class="old-price">{item.old_price}€</span>}
                            </div>
                            <p class="price-note">{priceTypeLabel}</p>

                            <div class="meta-list">
                                <div class="meta-row">
                                    <span class="meta-key">Angebot</span>
                                    <span class="meta-value">Startplatz</span>
                                </div>
                            </div>
                        </div>

                        <div class="card description-box">
                            <span class="label">Zusatzinfos</span>
                            <p>{item.description || 'Keine weiteren Details vom Verkäufer hinterlegt.'}</p>
                        </div>
                    </div>

                    <aside class="sidebar">
                        {seller && (
                            <div class="card seller-card-block">
                                <div class="seller-avatar-wrap">
                                    {seller.avatar_url
                                        ? <img src={seller.avatar_url} alt={seller.nickname ?? 'Verkäufer'} />
                                        : <span>👤</span>
                                    }
                                </div>
                                <div class="seller-info">
                                    <p class="seller-name">{seller.nickname || 'Anonym'}</p>
                                    {memberSince && <p class="seller-meta">Mitglied seit {memberSince}</p>}
                                </div>
                            </div>
                        )}

                        <div class="card contact-card">
                            <h3>Verkäufer kontaktieren</h3>
                            <p>Sende eine Nachricht, um Details oder die Übergabe zu klären.</p>

                            <form id="contact-form" data-seller-id={item.user_id}>
                                <input type="hidden" name="listing_id" value={item.id}>

                                <textarea name="message" placeholder="Hallo, ich interessiere mich für deinen Startplatz ..." class="input-field textarea" required></textarea>

                                <button type="submit" class="btn-cyan-glow" id="send-btn">Nachricht senden</button>
                            </form>
                            <p class="login-hint">🔒 Sicherer Chat via Startplatzbörse</p>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </main>
    
    <Footer /> 
</Layout>

<script>
    import { createClient } from '@supabase/supabase-js';
    import { initWatchlistUi } from '../../lib/watchlist';

    initWatchlistUi();

    // TEILEN LOGIK (Native Web Share API)
    const shareBtn = document.getElementById('share-btn');
    if (shareBtn) {
        shareBtn.addEventListener('click', async () => {
            const shareData = {
                title: document.title,
                text: 'Schau dir diesen Startplatz an:',
                url: window.location.href
            };

            if (navigator.share) {
                try {
                    await navigator.share(shareData);
                } catch (err) {
                    console.log('Teilen abgebrochen oder fehlgeschlagen', err);
                }
            } else {
                navigator.clipboard.writeText(window.location.href);
                const originalHTML = shareBtn.innerHTML;
                shareBtn.innerHTML = '✓ Link kopiert';
                setTimeout(() => { shareBtn.innerHTML = originalHTML; }, 2000);
            }
        });
    }

    // BACK-LOGIK
    const backBtn = document.getElementById('dynamic-back-btn');
    if (backBtn) {
        backBtn.addEventListener('click', (e) => {
            e.preventDefault(); 
            const urlParams = new URLSearchParams(window.location.search);
            const origin = urlParams.get('from');

            if (origin === 'search') {
                if (window.history.length > 1) {
                    window.history.back(); 
                } else {
                    window.location.href = '/suche';
                }
            } else {
                window.location.href = '/';
            }
        });
    }

    const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL, 
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    const form = document.getElementById('contact-form');
    
    document.addEventListener('DOMContentLoaded', () => {
        const savedDraft = localStorage.getItem('draft_msg');
        const textArea = document.querySelector('textarea[name="message"]');
        if (savedDraft && textArea && (textArea as HTMLTextAreaElement).value === "") {
            (textArea as HTMLTextAreaElement).value = savedDraft;
        }
    });

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('send-btn') as HTMLButtonElement;
            const originalText = btn.innerText;
            btn.innerText = "Prüfe...";
            btn.disabled = true;

            const formData = new FormData(form as HTMLFormElement);
            const messageText = formData.get('message');
            const listingId = formData.get('listing_id');
            const sellerId = (form as HTMLFormElement).dataset.sellerId;

            try {
                const { data: { user } } = await supabase.auth.getUser();

                if (!user) {
                    localStorage.setItem('draft_msg', messageText as string);
                    window.location.href = `/login?redirect=/listing/${listingId}`;
                    return; 
                }

                if (user.id === sellerId) {
                    alert("Du kannst dir nicht selbst schreiben.");
                    btn.innerText = originalText;
                    btn.disabled = false;
                    return;
                }

                const { data: existing } = await supabase
                    .from('conversations')
                    .select('id')
                    .eq('listing_id', listingId)
                    .eq('buyer_id', user.id)
                    .single();

                let chatId = existing?.id;

                if (!chatId) {
                    const { data: nc, error: ne } = await supabase
                        .from('conversations')
                        .insert({ listing_id: listingId, buyer_id: user.id, seller_id: sellerId })
                        .select().single();
                    if (ne) throw ne;
                    chatId = nc.id;
                }

                const { error: me } = await supabase.from('messages').insert({
                    conversation_id: chatId,
                    sender_id: user.id,
                    content: messageText
                });

                if (me) throw me;
                localStorage.removeItem('draft_msg');
                window.location.href = `/dashboard?chat_id=${chatId}`;

            } catch (err) {
                console.error(err);
                alert("Fehler beim Senden.");
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }); 
    }
</script>

<style>
    .listing-page { background: var(--bg-body); min-height: 100vh; padding: 100px 15px 60px; color: white; }
    .container { max-width: 1100px; margin: 0 auto; }
    .listing-layout { display: grid; gap: 14px; margin-top: 16px; }

    .hero-card {
        position: relative;
        overflow: hidden;
        border-radius: 20px;
        padding: 16px;
        border: 1px solid var(--border);
        background: var(--bg-card);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .hero-card::before {
        content: '';
        position: absolute;
        inset: 0 0 auto 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    }

    .hero-card::after {
        content: '';
        position: absolute;
        top: -40px;
        right: -30px;
        width: 180px;
        height: 180px;
        background: radial-gradient(circle, rgba(0, 188, 212, 0.14) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-top {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .header-actions-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .badge {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--cyan);
        background: rgba(0, 188, 212, 0.12);
        border: 1px solid rgba(0, 188, 212, 0.35);
    }

    .heart-btn,
    .share-btn {
        position: relative;
        z-index: 1;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: var(--bg-body);
        color: #dbe7ea;
        border-radius: 12px;
        height: 36px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .heart-btn { width: 36px; padding: 0; }
    .share-btn { gap: 6px; padding: 0 10px; font-size: 0.74rem; font-weight: 800; }
    .heart-icon { width: 17px; height: 17px; }
    .heart-btn:hover { color: var(--cyan); border-color: rgba(0, 188, 212, 0.7); }
    .heart-btn.is-saved { color: var(--cyan); border-color: var(--cyan); }
    .heart-btn.is-saved .heart-icon { fill: currentColor; }
    .heart-btn:disabled { opacity: 0.5; cursor: wait; }
    .share-btn:hover { color: var(--cyan); border-color: rgba(0, 188, 212, 0.7); }

    .glow-title {
        position: relative;
        z-index: 1;
        font-size: clamp(1.9rem, 3.4vw, 3rem);
        font-weight: 900;
        margin: 12px 0 14px;
        line-height: 1.1;
        color: #ffffff;
    }

    .event-facts {
        position: relative;
        z-index: 1;
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
    }

    @media (min-width: 640px) {
        .event-facts { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    .event-fact {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
    }

    @media (min-width: 640px) {
        .event-fact:has(.fact-multiline) { grid-column: 1 / -1; }
    }

    .fact-icon {
        flex-shrink: 0;
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--cyan);
        background: rgba(0, 188, 212, 0.1);
        border: 1px solid rgba(0, 188, 212, 0.2);
    }

    .fact-icon svg { width: 17px; height: 17px; }

    .fact-copy { min-width: 0; flex: 1; text-align: left; }

    .fact-label {
        display: block;
        font-size: 0.64rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #777;
        margin-bottom: 2px;
    }

    .fact-value {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
