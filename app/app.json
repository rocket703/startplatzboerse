{
  "expo": {
    "name": "Startplatzbörse",
    "slug": "startplatzboerse",
    "privacy": "hidden",
    "version": "1.0.0",
    "runtimeVersion": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
