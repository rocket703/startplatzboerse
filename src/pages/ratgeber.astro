---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

// 1. Artikel laden & sortieren
const allArticles = await getCollection('ratgeber');
const sortedArticles = allArticles.sort((a, b) => {
  const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
  const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
  return dateB - dateA;
});

const title = "Ratgeber & Magazin | Startplatzbörse";
const description = "Profitiere von Experten-Tipps zu Training, Ernährung und dem sicheren Kauf von Startplätzen.";
---

<Layout title={title} description={description}>
  <main>
    <header class="hero">
      <div class="hero-content">
        <span class="beta-badge">Wissen & Inspiration</span>
        <h1>Der <span class="text-cyan">Ratgeber</span></h1>
        <p class="hero-sub">
          Alles, was du für dein nächstes Rennen wissen musst. Von Athleten für Athleten.
        </p>
      </div>
    </header>

    <section class="ratgeber-section">
      <div class="container">

        <div class="ratgeber-grid">
          {sortedArticles.map((article) => (
            <a href={`/ratgeber/${article.data.slug || article.slug}`} class="ratgeber-card">
              <div 
                class="ratgeber-image" 
                style={`background-image: url(${article.data.image});`}
              >
              </div>
              <div class="ratgeber-content">
                <span class="badge" style="font-size: 0.7rem;">{article.data.category || 'Tipp'}</span>
                <h3>{article.data.title}</h3>
                <p>{article.data.description}</p>
                <div class="read-more">
                  Jetzt lesen 
                  <span style="margin-left: 8px;">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>

      </div>
    </section>
  </main>

   <Footer />

</Layout>

<style>
    /* --- VARIABLEN (Sync mit Startseite) --- */
    :root {
        --bg-actual: #323232; 
        --bg-card: #1a1a1a;   
        --cyan: #00bcd4;
        --text-muted: #aaa;
    }

    /* --- HERO (Exakt von Startseite kopiert) --- */
    .hero {
        min-height: 60vh; /* Etwas flacher als auf der Home */
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: linear-gradient(
            to bottom,
            #454545 0%,
            #383838 60%,
            var(--bg-actual) 100%
        );
        padding: 140px 20px 80px;
    }

    .hero-content {
        max-width: 900px;
        z-index: 10;
    }

    .beta-badge {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #888;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 8px 20px;
        border-radius: 50px;
        display: inline-block;
        margin-bottom: 25px;
    }

    h1 {
        font-size: clamp(2.8rem, 9vw, 5.5rem);
        font-weight: 900;
        line-height: 1.05;
        margin: 0 0 30px 0;
        letter-spacing: -3px;
        color: white;
    }

    .text-cyan { 
        color: var(--cyan); 
        text-shadow: 0 0 40px rgba(0, 188, 212, 0.3); 
    }

    .hero-sub {
        font-size: 1.3rem;
        color: var(--text-muted);
        max-width: 650px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* --- CONTENT SECTION --- */
    .ratgeber-section {
        padding: 80px 0 120px;
        background-color: var(--bg-actual);
    }

    .container { 
        max-width: 1200px; 
        margin: 0 auto;
        padding: 0 20px;
    }

    .section-header {
        margin-bottom: 60px;
    }

    .badge { 
        color: var(--cyan); 
        font-weight: 800; 
        text-transform: uppercase; 
        font-size: 0.8rem; 
        letter-spacing: 1px; 
    }

    h2 { 
        font-size: 2.8rem; 
        color: white; 
        font-weight: 900; 
        margin-top: 10px; 
        letter-spacing: -1px; 
    }

    /* --- GRID & CARDS (Exakt von Startseite kopiert) --- */
    .ratgeber-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
    }

    .ratgeber-card {
        background: var(--bg-card);
        border-radius: 20px;
        overflow: hidden;
        text-decoration: none;
        transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.3s ease;
        border: 5px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
    }

    .ratgeber-card:hover {
        transform: translateY(-8px);
        border-color: var(--cyan);
    }

    .ratgeber-image {
        height: 250px;
        background-size: cover;
        background-position: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .ratgeber-content {
        padding: 35px;
        flex-grow: 1;
    }

    .ratgeber-content h3 {
        color: white;
        font-size: 1.8rem;
        margin: 10px 0 15px;
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: -0.5px;
    }

    .ratgeber-content p {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.6;
        margin-bottom: 25px;
    }

    .read-more {
        color: var(--cyan);
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 768px) {
        .ratgeber-grid {
            grid-template-columns: 1fr;
        }
        h1 { font-size: 3.5rem; }
        h2 { font-size: 2.2rem; }
        .hero { min-height: 50vh; padding-top: 100px; }
    }
</style>