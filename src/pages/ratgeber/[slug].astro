---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

const { slug } = Astro.params;
const entry = await getEntry('ratgeber', slug as string);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await entry.render();
---

<Layout 
  title={entry.data.title}
  description={entry.data.teaser}
  image={entry.data.image}
  ogType="article"
>
  <main class="article-page">
    <header class="article-hero" style={`background-image: linear-gradient(to bottom, rgba(50,50,50,0.2) 0%, #323232 100%), url(${entry.data.image});`}>
  <div class="container">
    <div class="article-meta">
      <span class="badge-cyan">{entry.data.category || 'Ratgeber'}</span>
      {entry.data.readingTime && <span class="read-time">{entry.data.readingTime}</span>}
    </div>
    <h1>{entry.data.title}</h1>
  </div>
</header>

    <section class="article-body">
      <div class="container container-narrow">
        <div class="prose">
          <Content />
        </div>

        <div class="article-cta">
          <h3>Dein Plan hat sich geändert?</h3>
          <p>Lass dein Ticket nicht verfallen. Inseriere es jetzt kostenlos in der Community.</p>
          <div class="cta-actions">
            <a href="/inserieren" class="btn-primary">Startplatz inserieren</a>
            <a href="/" class="btn-ghost">Zur Übersicht</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  /* --- 1. GRUND-LAYOUT --- */
  .article-page {
    background-color: #323232; /* Angepasst an deine Startseite */
    color: #eee;
    min-height: 100vh;
    overflow-x: hidden; 
  }

  .container {
    max-width: 1280px; 
    margin: 0 auto;
    padding: 0 20px;
  }

  .container-narrow {
    max-width: 880px; 
  }

  /* --- 2. HERO SEKTION --- */
  .article-hero {
    min-height: 550px;
    height: 70vh;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
    padding-top: 160px; 
    padding-bottom: 60px;
    position: relative;
  }

  .article-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(44,44,44,0.2) 0%, #323232 100%);
    z-index: 1;
  }

  .article-hero .container {
    width: 100%;
    z-index: 2;
    position: relative;
  }

  .article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between; 
    width: 100%;
    margin-bottom: 25px;
  }

  .badge-cyan {
    background: rgba(0, 188, 212, 0.1);
    color: #00bcd4;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border: 1px solid #00bcd4;
  }

  .read-time {
    color: #00bcd4;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.2rem, 7vw, 4.2rem);
    font-weight: 900;
    line-height: 1.05;
    color: white;
    letter-spacing: -3px;
    margin: 0;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  /* --- 3. ARTIKEL BODY & TYPOGRAFIE --- */
  .article-body {
    padding: 80px 0 120px;
  }

  .prose {
    font-size: 1.2rem;
    line-height: 1.8;
    color: #ccc;
  }

  .prose :global(h2) {
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    color: white;
    font-weight: 900;
    margin: 6rem 0 2rem; 
    line-height: 1.2;
    letter-spacing: -1px;
  }

  .prose :global(p) {
    margin-bottom: 1.8rem;
  }

  .prose :global(blockquote) {
    border-left: 5px solid #ff8c00;
    background: #222222;
    padding: 30px;
    margin: 4rem 0;
    border-radius: 0 12px 12px 0;
    font-style: italic;
    font-size: 1.35rem;
    color: white;
    line-height: 1.6;
  }

  /* --- 4. CLEANE KARTEN (WIE AUF STARTSEITE, OHNE ZAHLEN) --- */
  .prose :global(ul), 
  .prose :global(ol) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    margin: 4rem 0;
    padding: 0 !important;
    list-style: none !important;
  }

  .prose :global(ul li), 
  .prose :global(ol li) {
    background-color: #222222;
    border: 5px solid rgba(255,255,255,0.05);
    padding: 30px;
    border-radius: 16px !important; 
    margin: 0;
    transition: all 0.3s ease;
    
    display: flex !important; 
    flex-direction: column !important;
    list-style-type: none !important; 
  }

  .prose :global(ul li:hover), 
  .prose :global(ol li:hover) {
    border-color: #00bcd4 !important; /* Volles Neon-Cyan beim Hover */
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .prose :global(li strong) {
    display: block;
    color: white; /* Weiß sieht edler aus */
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  /* KILLSWITCH FÜR DIE ZAHLEN */
  .prose :global(ol li::before),
  .prose :global(ul li::before),
  .prose :global(ol li::marker),
  .prose :global(ul li::marker) {
    content: none !important;
    display: none !important;
  }


  /* --- 5. CTA BOX AM ENDE --- */
  .article-cta {
    margin-top: 100px;
    background-color: #222222;
    border: 5px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 60px 40px;
    text-align: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .article-cta h3 {
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    color: white;
    margin-bottom: 15px;
    font-weight: 900;
  }

  .article-cta p {
    color: #aaa;
    margin-bottom: 35px;
    font-size: 1.1rem;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .btn-primary, .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 220px;
    height: 55px; /* Etwas schlanker */
    padding: 0 30px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.05rem;
    border: 5px solid #00bcd4;
    box-sizing: border-box;
    transition: all 0.3s ease;
  }

  .btn-primary { background: #00bcd4; color: #121212; }
  .btn-ghost { background: transparent; color: white; }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 188, 212, 0.2);
    color: #121212;
  }
  .btn-ghost:hover {
    color: white;
    border-color: white;
  }

  /* --- TABELLEN STYLING (FINAL & KOMPLETT) --- */
  
  .prose :global(table) {
    width: 100%;
    margin: 4rem 0;
    background-color: #222222;
    border: 5px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    
    /* Mobile-Scrolling & Zeilenumbrüche */
    display: block; 
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    white-space: normal; 
    
    /* Ecken-Fix */
    border-collapse: separate !important; 
    border-spacing: 0;
  }

  /* Sichert ab, dass die Kopfzeile nicht über die runden Ecken blutet */
  .prose :global(th:first-child) { border-top-left-radius: 10px; }
  .prose :global(th:last-child) { border-top-right-radius: 10px; }

  .prose :global(th) {
    color: #00bcd4; /* Das fehlende Cyan! */
    font-weight: 800;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 20px 25px; /* Bringt die Luft zum Atmen zurück */
    text-align: left;
    border-bottom: 2px solid #333333; /* Feste Trennlinie unter dem Kopf */
    min-width: 140px; /* Zwingt die Tabelle auf dem Handy zum Scrollen statt Quetschen */
  }

  .prose :global(td) {
    padding: 20px 25px;
    color: #ccc;
    font-size: 1.05rem;
    line-height: 1.6;
    border-bottom: 1px solid #222222; /* Feine Trennlinien zwischen den Zeilen */
    min-width: 140px; 
    transition: background-color 0.3s ease;
  }

  /* Letzte Zeile braucht keinen Strich unten */
  .prose :global(tr:last-child td) { 
    border-bottom: none; 
  }
  
  /* Leichter Hover-Effekt für die Tabellenzeilen */
  .prose :global(tbody tr:hover td) { 
    background-color: #1a1a1a; 
  }
</style>