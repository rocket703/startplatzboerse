---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import SocialShare from '../components/SocialShare.astro';
import Footer from '../components/Footer.astro';
import Infos from '../components/Infos.astro';
import Faq from '../components/Faq.astro';
import EventCard from '../components/EventCard.astro';
import { createClient } from '@supabase/supabase-js';
import { getCollection } from 'astro:content';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

// Wir holen alle genehmigten Inserate, sortiert nach Datum (neuere zuerst)
const { data: listings, error } = await supabase
  .from('listings')
  .select(`
    *,
    profiles (nickname)
  `)
  .eq('approved', true)
  .eq('status', 'active')
  .order('created_at', { ascending: false })
  .limit(4);

  // ARTIKEL AUF STARTSEITE ALDEN UND SORTIEREN
 const allRatgeber = await getCollection('ratgeber');

const ratgeberTeaser = allRatgeber
  .sort((a, b) => {
    // Wir wandeln beide Daten in Zahlen um und vergleichen sie
    return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
  })
  .slice(0, 4);
---

<Layout title="Startplätze kaufen & verkaufen">
    
    <div class="hero">
        <div class="hero-content">
            <div class="badge-container">
                <SocialShare />
            </div>

            <h1>Dein Rennen.<br> <span class="text-cyan">Mein Startplatz.</span></h1>
            
            <p class="hero-sub">
                Die neue Plattform für Lauf, Rad, Triathlon & Hyrox.<br>
                Fair. Transparent. <strong>Von privat an privat.</strong>
            </p>
            
            <div class="btn-group">
                <a href="#listings" class="btn-primary">Startplatz finden</a>
                <a href="/inserieren" class="btn-secondary">Platz inserieren</a>
            </div>
        </div>
    </div>

 <section class="trust-box-section">
    <div class="container">
        
        <div class="trust-grid">
            
           <div class="trust-card">
                <div class="trust-icon-container">
                    <svg class="trust-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                    </svg>
                    <div class="icon-glow"></div>
                </div>
                <h3>Echte Community</h3>
                <p>Von Privat an Privat. Du kaufst direkt von anderen Athleten. Wir stellen die Technik bereit, damit ihr euch findet. Ohne Zwischenhändler.</p>
            </div>

            <div class="trust-card">
                <div class="trust-icon-container">
                    <svg class="trust-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751A11.959 11.959 0 0112 2.714z" />
                    </svg>
                    <div class="icon-glow"></div>
                </div>
                <h3>Faire Abwicklung</h3>
                <p>Direkte Kommunikation zwischen dem Verkäufer und dir. Seid Fair zu einander und gestaltet so ein postives Erlebnis für uns Alle.</p>
            </div>

            <div class="trust-card">
                <div class="trust-icon-container">
                    <svg class="trust-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                    </svg>
                    <div class="icon-glow"></div>
                </div>
                <h3>Einfach & Schnell</h3>
                <p>In 2 Minuten inseriert, blitzschnell gefunden. Egal ob Last-Minute oder lang geplanter Start. Hier wird jeder fündig.</p>
            </div>

        </div>
    </div>
</section>

  <section class="listings-preview" id="listings">
    <div class="container">
        <div class="section-header">
            <div class="header-title">
                <span class="badge">Aktuell</span>
                <h2>Neueste Inserate</h2>
            </div>
            </div>

        <div class="event-grid">
            {listings && listings.map((item: any) => (
                <EventCard 
                    id={item.id}
                    category={item.category}
                    title={item.event_name}
                    date={new Date(item.event_date).toLocaleDateString('de-DE')}
                    location={item.location}
                    distance={item.distance}
                    price={item.price}
                    oldPrice={item.old_price}
                    nickname={item.profiles?.nickname || "Gast"}
                />
            ))}
        </div>
            
        {(!listings || listings.length === 0) && (
            <p class="no-listings">Aktuell keine Startplätze verfügbar. Inseriere den ersten!</p>
        )}

        <div class="section-footer">
            <a href="/suche" class="view-all">Alle anzeigen →</a>
        </div>
    </div> 
</section>

    <Infos />

    <section class="listings-preview">
    <div class="container">
        <div class="section-header">
            <div class="header-title">
                <span class="badge">Wissen & Tipps</span>
                <h2>Ratgeber</h2>
            </div>
            </div>

        <div class="ratgeber-grid">
            {ratgeberTeaser.map((artikel) => (
                <a href={`/ratgeber/${artikel.slug}`} class="ratgeber-card">
                    <div class="ratgeber-image" style={`background-image: url(${artikel.data.image})`}></div>
                    <div class="ratgeber-content">
                        <h3>{artikel.data.title}</h3>
                        <p>{artikel.data.teaser}</p>
                        <span class="read-more">Artikel lesen →</span>
                    </div>
                </a>
            ))}
        </div>

        <div class="section-footer">
             <a href="/ratgeber" class="view-all">Alle anzeigen →</a>
        </div>
    </div>
</section>

    <Faq />

    <Footer />

</Layout>

<style>
    /* --- VARIABLEN & RESET --- */
    :root {
        --bg-actual: #323232; /* Dein Haupt-Hintergrund */
