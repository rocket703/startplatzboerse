        background: var(--bg-card);
        border-radius: 20px;
        overflow: hidden;
        text-decoration: none;
        transition: transform 0.3s ease, border-color 0.3s ease;
        border: 5px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
    }

    .ratgeber-card:hover {
        transform: translateY(-5px);
        border-color: var(--cyan);
    }

