        height: 80px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .trust-icon {
        width: 50px;
        height: 50px;
        color: var(--cyan); /* Brandfarbe nutzen */
        z-index: 2; /* Über dem Glow */
    }

    .icon-glow {
        position: absolute;
        width: 100%;
        height: 100%;
        background: var(--cyan);
        border-radius: 50%;
        filter: blur(35px); /* Macht den weichen Glow-Effekt */
        opacity: 0.15; /* Ganz dezent halten */
